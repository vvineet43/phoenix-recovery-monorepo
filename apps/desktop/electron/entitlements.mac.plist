<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for all apps using hardened runtime -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Allow loading dylibs not signed by Apple (for Electron V8 snapshots) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Required for raw disk access (will still need sudo escalation at runtime) -->
  <key>com.apple.security.temporary-exception.iokit-user-client-class</key>
  <array>
    <string>IOBlockStorageUserClient</string>
  </array>
</dict>
</plist>
